# ===========================================
# sharif-chain-scope — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ===========================================

# Stellar Horizon RPC URL
# Testnet: https://horizon-testnet.stellar.org
# Mainnet: https://horizon.stellar.org
VITE_HORIZON_URL=https://horizon-testnet.stellar.org

# Stellar Network Passphrase
# Testnet: Test SDF Network ; September 2015
# Mainnet: Public Global Stellar Network ; September 2015
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban RPC endpoint for smart contract interactions
# Testnet: https://soroban-testnet.stellar.org
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Application settings
VITE_APP_NAME=sharif-chain-scope

# API request timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# WebSocket endpoint for real-time ledger/transaction streaming (issue #74)
# Leave unset to disable the live stream panel.
# Example: wss://your-ws-server.example.com/ledger
# VITE_LEDGER_WS_URL=
